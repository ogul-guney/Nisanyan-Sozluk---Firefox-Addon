{
  "manifest_version": 3,
  "name": "Nişanyan: Hızlı Arama",
  "version": "2.0",
  "permissions": ["contextMenus", "tabs", "storage"],
  "icons": {
    "16": "icons/nisanyan.png",
    "32": "icons/nisanyan.png",
    "48": "icons/nisanyan.png",
    "128": "icons/nisanyan.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_icon": "icons/nisanyan.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
